{
  "version": 2,
  "builds": [
    { "src": "Ejercicio 3/server/src/index.js", "use": "@vercel/node" },
    { "src": "Ejercicio 1/**", "use": "@vercel/static" },
    { "src": "Ejercicio 2/**", "use": "@vercel/static" },
    { "src": "Ejercicio 3/client/**", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/Ejercicio 3/server/src/index.js" },
    { "source": "/Ejercicio 3/(.*)", "destination": "/Ejercicio 3/client/$1" }
  ]
}